# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
# Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

**/.DS_Store

# qemu log file
qemu.log
qemu-serial.log

# packet dump file
virtio-net.pcap

# vscode launch config file
.vscode/launch.json
.vscode/launch.bak

# benchmark results
/result_*.json
.local/
target_lby/
.cache/
.target_bench/

# profile results
aster-kernel-profile-*.json
aster-kernel-profile-*.folded
aster-kernel-profile-*.svg

# distro results
distro/result

# cachix package list
cachix.list

# temporary configuration file for NixOS tests
distro/etc_nixos/_config_for_test.nix
/.target_check/

# Local benchmark run artifacts. Evidence files that must be versioned
# (summary TSVs, crash matrices, retained patches) are added explicitly
# with `git add -f`.
benchmark/logs/
