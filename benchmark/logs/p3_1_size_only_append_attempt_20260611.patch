+    /// P3 (Phase 6): like `collect_block_ranges` but includes *unwritten*
+    /// (preallocated) extents, i.e. reports every ALLOCATED block. Used by the
+    /// size-only append fast path to decide that a write range needs no block
+    /// allocation (only an i_size update); the unwritten->written conversion
+    /// is deferred to writeback. Never use this for reads: unwritten blocks
+    /// hold uninitialized device content.
+    fn collect_allocated_ranges(
+        &self,
+        inode_ref: &Ext4InodeRef,
+        lblock_start: u32,
+        lblock_count: u32,
+    ) -> Result<Vec<SimpleBlockRange>> {
+        if lblock_count == 0 {
+            return Ok(Vec::new());
+        }
+        let lblock_end = lblock_start
+            .checked_add(lblock_count)
+            .ok_or_else(|| Ext4Error::new(Errno::EFBIG))?;
+        let uses_extents = (inode_ref.inode.flags() & EXT4_INODE_FLAG_EXTENTS as u32) != 0;
+        let mut mappings = Vec::new();
+        let mut cursor = lblock_start;
+
+        if !uses_extents {
+            // Legacy inodes have no unwritten state; reuse the read-semantics
+            // walk (identical block set).
+            return self.collect_block_ranges(inode_ref, lblock_start, lblock_count);
+        }
